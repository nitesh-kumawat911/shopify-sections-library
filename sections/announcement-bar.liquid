{%- comment -%}
  Announcement Bar section
  Slim top bar for promos / shipping messages. Optional link, custom colors,
  and a dismiss button that remembers the choice for the session.
{%- endcomment -%}

{%- assign bar_id = 'announcement-' | append: section.id -%}

<div
  id="{{ bar_id }}"
  class="announcement"
  style="--bar-bg: {{ section.settings.bg_color }}; --bar-text: {{ section.settings.text_color }};"
>
  <div class="announcement__inner">
    {%- if section.settings.link != blank -%}
      <a class="announcement__text" href="{{ section.settings.link }}">
        {{ section.settings.message | escape }}
      </a>
    {%- else -%}
      <span class="announcement__text">{{ section.settings.message | escape }}</span>
    {%- endif -%}

    {%- if section.settings.show_close -%}
      <button
        type="button"
        class="announcement__close"
        aria-label="Dismiss announcement"
        data-bar="{{ bar_id }}"
      >&times;</button>
    {%- endif -%}
  </div>
</div>

{%- if section.settings.show_close -%}
  <script>
    (function () {
      var id = {{ bar_id | json }};
      var bar = document.getElementById(id);
      if (!bar) return;
      if (sessionStorage.getItem('hide-' + id) === '1') {
        bar.style.display = 'none';
        return;
      }
      var btn = bar.querySelector('.announcement__close');
      if (btn) {
        btn.addEventListener('click', function () {
          bar.style.display = 'none';
          sessionStorage.setItem('hide-' + id, '1');
        });
      }
    })();
  </script>
{%- endif -%}

{%- style -%}
  .announcement {
    background: var(--bar-bg, #1a1a1a);
    color: var(--bar-text, #ffffff);
    font-size: 0.9rem;
  }
  .announcement__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    position: relative;
  }
  .announcement__text {
    color: inherit;
    text-decoration: none;
    text-align: center;
  }
  .announcement__text:hover { text-decoration: underline; }
  .announcement__close {
    position: absolute;
    right: 12px;
    background: none;
    border: 0;
    color: inherit;
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.8;
  }
  .announcement__close:hover { opacity: 1; }
{%- endstyle -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "section-announcement",
  "settings": [
    { "type": "text", "id": "message", "label": "Message", "default": "Free shipping on orders over $50" },
    { "type": "url", "id": "link", "label": "Link (optional)" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#1a1a1a" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "checkbox", "id": "show_close", "label": "Show dismiss button", "default": true }
  ],
  "presets": [
    { "name": "Announcement Bar" }
  ]
}
{% endschema %}
