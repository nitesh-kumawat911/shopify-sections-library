{%- comment -%}
  Hero Banner section
  A full-width hero with a background image, heading, subtext and a CTA button.
  Supports separate mobile and desktop images, and configurable text alignment.
{%- endcomment -%}

<section class="hero-banner" style="--hero-overlay: {{ section.settings.overlay_opacity }};">
  {%- if section.settings.image_desktop != blank -%}
    <img
      class="hero-banner__img hero-banner__img--desktop"
      src="{{ section.settings.image_desktop | image_url: width: 2000 }}"
      srcset="{{ section.settings.image_desktop | image_url: width: 800 }} 800w,
              {{ section.settings.image_desktop | image_url: width: 1600 }} 1600w,
              {{ section.settings.image_desktop | image_url: width: 2000 }} 2000w"
      sizes="100vw"
      alt="{{ section.settings.image_desktop.alt | escape }}"
      width="{{ section.settings.image_desktop.width }}"
      height="{{ section.settings.image_desktop.height }}"
      loading="eager"
    >
  {%- endif -%}

  {%- if section.settings.image_mobile != blank -%}
    <img
      class="hero-banner__img hero-banner__img--mobile"
      src="{{ section.settings.image_mobile | image_url: width: 1000 }}"
      alt="{{ section.settings.image_mobile.alt | escape }}"
      loading="eager"
    >
  {%- endif -%}

  <div class="hero-banner__content hero-banner__content--{{ section.settings.text_align }}">
    {%- if section.settings.heading != blank -%}
      <h2 class="hero-banner__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <div class="hero-banner__subtext">{{ section.settings.subtext }}</div>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="hero-banner__btn">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</section>

{%- style -%}
  .hero-banner {
    position: relative;
    min-height: {{ section.settings.height }}px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-banner__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-banner::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--hero-overlay, 0.3));
    z-index: 1;
  }
  .hero-banner__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
    color: #fff;
  }
  .hero-banner__content--center { text-align: center; }
  .hero-banner__content--right  { text-align: right; }
  .hero-banner__heading {
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    margin: 0 0 0.5em;
  }
  .hero-banner__subtext {
    font-size: 1.1rem;
    margin-bottom: 1.4em;
  }
  .hero-banner__btn {
    display: inline-block;
    padding: 12px 30px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
  }
  .hero-banner__img--mobile { display: none; }
  @media (max-width: 749px) {
    .hero-banner__img--desktop { display: none; }
    .hero-banner__img--mobile  { display: block; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    { "type": "image_picker", "id": "image_desktop", "label": "Desktop image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile image" },
    { "type": "range", "id": "height", "min": 200, "max": 800, "step": 20, "unit": "px", "label": "Section height", "default": 480 },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 1, "step": 0.1, "label": "Overlay opacity", "default": 0.3 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your headline goes here" },
    { "type": "richtext", "id": "subtext", "label": "Subtext", "default": "<p>A short supporting line of text.</p>" },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#1a1a1a" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#ffffff" }
  ],
  "presets": [
    { "name": "Hero Banner" }
  ]
}
{% endschema %}
