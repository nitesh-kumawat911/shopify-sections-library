{%- comment -%}
  Testimonials section
  Review/testimonial grid. Each testimonial is a block with a quote, author,
  optional role and a star rating (1-5).
{%- endcomment -%}

<section class="reviews">
  {%- if section.settings.heading != blank -%}
    <h2 class="reviews__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="reviews__grid" style="--cols: {{ section.settings.columns }};">
    {%- for block in section.blocks -%}
      <figure class="review" {{ block.shopify_attributes }}>
        {%- if block.settings.rating > 0 -%}
          <div class="review__stars" aria-label="{{ block.settings.rating }} out of 5">
            {%- for i in (1..5) -%}
              <span class="review__star{% if i <= block.settings.rating %} is-filled{% endif %}">&#9733;</span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <blockquote class="review__quote">{{ block.settings.quote }}</blockquote>

        <figcaption class="review__author">
          <strong>{{ block.settings.author | escape }}</strong>
          {%- if block.settings.role != blank -%}
            <span class="review__role">{{ block.settings.role | escape }}</span>
          {%- endif -%}
        </figcaption>
      </figure>
    {%- else -%}
      <p>Add your first testimonial from the theme editor.</p>
    {%- endfor -%}
  </div>
</section>

{%- style -%}
  .reviews {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  .reviews__heading {
    text-align: center;
    margin-bottom: 1.5em;
  }
  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: 20px;
  }
  .review {
    margin: 0;
    padding: 22px;
    border: 1px solid #eee;
    border-radius: 8px;
    background: #fff;
  }
  .review__stars {
    color: #ddd;
    margin-bottom: 10px;
    font-size: 1.1rem;
  }
  .review__star.is-filled { color: #f5b50a; }
  .review__quote {
    margin: 0 0 14px;
    font-style: italic;
    color: #333;
    line-height: 1.6;
  }
  .review__author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .review__role {
    font-size: 0.85rem;
    color: #888;
  }
  @media (max-width: 749px) {
    .reviews__grid { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What our customers say" },
    { "type": "range", "id": "columns", "min": 1, "max": 4, "step": 1, "label": "Columns (desktop)", "default": 3 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "richtext", "id": "quote", "label": "Quote", "default": "<p>Great product and fast shipping. Highly recommended!</p>" },
        { "type": "text", "id": "author", "label": "Author", "default": "Jane D." },
        { "type": "text", "id": "role", "label": "Role / location", "default": "Verified buyer" },
        { "type": "range", "id": "rating", "min": 0, "max": 5, "step": 1, "label": "Star rating", "default": 5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
